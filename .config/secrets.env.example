# =============================================================================
# crayhillRebrand — secrets.env.example
# =============================================================================
# This is the COMMITTED template for .config/secrets.env. Copy it to
# .config/secrets.env (which is gitignored) and fill in real values.
#
#   cp .config/secrets.env.example .config/secrets.env
#
# Add a key here whenever you add a new secret to .config/secrets.env, with a
# placeholder value and a one-line comment describing what it's for. This file
# is the canonical list of every secret the project expects to find.
# =============================================================================

# --- Application ------------------------------------------------------------
# APP_ENV: one of development | staging | production
APP_ENV=development
# APP_DEBUG: true to surface verbose errors locally; must be false in production
APP_DEBUG=true

# --- MariaDB (AWS RDS) ------------------------------------------------------
# DB_HOST: RDS endpoint, e.g. <name>.<id>.<region>.rds.amazonaws.com
DB_HOST=
# DB_PORT: 3306 by default for MariaDB/MySQL on RDS
DB_PORT=3306
# DB_NAME: the database (schema) the app uses. Set after migration 001 runs.
DB_NAME=crayhill

# Runtime app user — used by the API for normal queries. The user is created
# by migration 002 with least privilege (SELECT/INSERT/UPDATE/DELETE on
# crayhill.* only). DO NOT use admin/root credentials here.
# DB_PASSWORD must match what migration 002 applied (or what you'd like
# applied: the migration substitutes this value at apply time).
DB_USER=crayhill_app
DB_PASSWORD=

# Admin user — used ONLY by api/lib/migrate.php for DDL.
# Reserve admin credentials for migrations; never wire them into the runtime
# API. In production, prefer injecting these via the deploy environment
# for the duration of the migration step rather than persisting in this file.
DB_ADMIN_USER=admin
DB_ADMIN_PASSWORD=

# --- CORS / API base --------------------------------------------------------
# ALLOWED_ORIGINS: comma-separated list of origins the API will accept.
# Local dev: http://localhost:5173 (Vite default). Production: https://crayhill.com
ALLOWED_ORIGINS=http://localhost:5173

# --- Future slots (uncomment and fill when the corresponding feature lands) -
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
#
# AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
#
# SESSION_SECRET=
# CSRF_SECRET=
#
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
