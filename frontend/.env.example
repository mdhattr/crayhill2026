# Public, build-time Vite vars for the frontend. Everything here ships to the
# browser in plaintext, so NEVER put a secret in this file (secrets live in
# .config/secrets.env and are read only by the PHP API). See INSTALL.md.

# Base URL the SPA uses to reach the PHP API.
# Relative (default) so the same value works in every environment:
#   - dev: the Vite dev server proxies /api -> the local PHP server
#   - prod: Apache serves /api on the same origin as the SPA
# Set to a full origin (e.g. https://api.example.com/v1) only for a
# cross-origin API host.
VITE_API_BASE_URL=/api/v1
